# reset or revert   / 과거로 돌아가는 두 가지 방법
# 커밋 해시는 "git log"를 통해 얻을 수 있음 / ex) commit b4a531b02fc2fe4c7fc477eb9affc419403f6dac
git reset --hard (돌아갈 커밋 해시) # 해당 커밋 상태로 초기화   / ex) git reset --hard b4a531b
git reset --hard    # 마지막 커밋으로 이동

git revert (되돌릴 커밋 해시)   # 해당 커밋 변경 사항을 역으로 되돌림(삭제된 파일은 복구...)    / ":wq"로 종료
# conflict 발생 / ex) 새로 파일을 생성한 커밋으로 revert 할 때 현재 커밋과 되돌릴 커밋 사이에서 해당 파일을 수정한 내역이 있을 때 발생
git revert --no-commit (되돌릴 커밋 해시)   # 원하는 다른 작업을 추가로 진행 후 커밋    / 취소하려면 "git reset --hard"사용 

# Branch: 분기된 가지 (다른 차원)   / 용도에 따라 사용 혹은 독립된 작업이 필요 할 때 등 여러 방법으로 사용됨
git Branch  # branch 목록 확인
git branch <branch name>    # <branch name>이란 이름의 브랜치 생성
git switch <branch name>    # <branch name>브랜치로 이동    / "checkout"명령어가 Git 2.23 버전부터 "switch", "restore"로 분리
git switch -c <branch name> # 브랜치 생성과 동시에 이동 / 기존에는 "git checkout -b <branch name>"사용
git branch -d <branch name> # 해당 브랜치 삭제  / 지워질 브랜치에만 있는 내용의 커밋이 있을 경우 "-d"대신 "-D"를 사용해
git branch -m <existing branch name> <new branch name>  # 브랜치 이름 바꾸기

git log --all --decorate --online --graph   # 여러 브랜치의 내역을 볼 수 있음   / "git log"에서는 현재 브랜치의 내역만 확인
